ENVIRONMENT=development
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:4200

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=subscription_db

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
EMAIL_QUEUE_NAME=email-queue

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_MAX_REQUESTS=5
RATE_LIMIT_GOOGLE_LOGIN_MAX_REQUESTS=10
RATE_LIMIT_FORGET_PASSWORD_MAX_REQUESTS=5
RATE_LIMIT_VALIDATE_CODE_MAX_REQUESTS=10

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
SMTP_TIMEOUT_SECONDS=15
SMTP_USE_STARTTLS=true

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
